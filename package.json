{
  "name": "embers-echoes",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/elyseeJuly/embers-echoes.git"
  },
  "author": "Michael Townsend <michael@doublespeakgames.com>",
  "license": "MPL-2.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "deploy:cf": "CF_PAGES=1 npm run build && wrangler pages deploy ./dist --project-name=embers-echoes",
    "start": "node dev-server.js",
    "update_pot": "pybabel extract -F lang/babel.cfg -c \"TRANSLATORS\" script -o lang/adarkroom.pot"
  },
  "dependencies": {
    "express": "^4.17.1"
  },
  "description": "*“在热寂的绝对零度中，寻找最后一丝理智的火花。”*",
  "main": "dev-server.js",
  "directories": {
    "doc": "docs",
    "lib": "lib"
  },
  "keywords": [],
  "bugs": {
    "url": "https://github.com/elyseeJuly/embers-echoes/issues"
  },
  "homepage": "https://github.com/elyseeJuly/embers-echoes#readme",
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "gh-pages": "^6.3.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-static-copy": "^4.1.1",
    "wrangler": "^4.107.0"
  },
  "packageManager": "npm"
}
